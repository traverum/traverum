{
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && pnpm --filter @traverum/widget build",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/auto-complete",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/completion-check",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/expire-unpaid",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/expire-reservations",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/sync-divinea",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/attendance-reminder",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/generate-invoices",
      "schedule": "0 6 1 * *"
    }
  ]
}
