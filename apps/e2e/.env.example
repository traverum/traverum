# Staging Supabase credentials for E2E tests.
# Copy this to .env and fill in values from your traverum-staging Supabase project.

NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required for the widget to not crash on startup (can be dummy values for UI tests)
STRIPE_SECRET_KEY=sk_test_dummy
TOKEN_SECRET=e2e-test-token-secret
