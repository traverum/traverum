{
  "name": "traverum",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@8.15.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:widget": "pnpm --filter @traverum/widget dev",
    "dev:dashboard": "pnpm --filter @traverum/dashboard dev",
    "dev:admin": "pnpm --filter @traverum/admin dev",
    "build": "turbo run build",
    "build:widget": "pnpm --filter @traverum/widget build",
    "build:dashboard": "pnpm --filter @traverum/dashboard build",
    "build:admin": "pnpm --filter @traverum/admin build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:pull": "turbo run test",
    "test:watch": "turbo run test:watch",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "turbo": "^2.0.0",
    "vitest": "^4.1.0"
  }
}
